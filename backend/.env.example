# Reflektionsarkiv – backend miljövariabler
# Kopiera till .env:  copy .env.example .env  (Windows)  eller  cp .env.example .env  (Mac/Linux)
# Fyll i dina värden nedan.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=reflektionsarkiv
# Lokal utveckling: ofta root. Produktion: reflektionsarkiv_app (se database/scripts/grants.sql).
# Schema/migrationer: kör som root eller reflektionsarkiv_admin — inte app-kontot (docs/DATABASE_SAKERHET.md).
DB_USER=root
# Tom = lokal MySQL utan root-lösenord. Med MySQL via docker compose i repo-roten: sätt DB_PASSWORD=tydaren_local_dev
DB_PASSWORD=

# JWT för Bearer-autentisering (byt till stark slump i produktion: openssl rand -hex 32)
JWT_SECRET=tyda-dev-jwt-secret-bytes-i-produktion
JWT_EXPIRE_HOURS=168

# Valfritt: AI-tolkning (server-side, nyckel exponeras aldrig i frontend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Valfritt: kommaseparerade modell-id:n som får erbjudas (tom = alla i backend-katalogen)
OPENAI_MODEL_ALLOWLIST=
